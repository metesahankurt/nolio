{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nolio",
  "version": "2.5.0",
  "identifier": "com.metesahankurt.nolio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nolio",
        "width": 1100,
        "height": 740,
        "minWidth": 680,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwOTI5QkY2RkQxQTRBOEYKUldTUFNocjk5cHVTSUJOOWppalNWSE1ISGo4cXVrdFhPbS9SL0daQTBqOURCYjRrZlVacDVvakwK",
      "endpoints": [
        "https://github.com/metesahankurt/nolio/releases/latest/download/latest.json"
      ]
    }
  }
}
